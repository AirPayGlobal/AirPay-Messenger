# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/airpay_messenger

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret

# WhatsApp
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Anthropic AI (optional)
ENABLE_ANTHROPIC=false
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_API_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-mini
# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/airpay_messenger?schema=public"

# Redis (for Bull Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# API Keys (for internal service authentication)
MASTER_API_KEY=your-master-api-key-change-this

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# AWS SNS (SMS)
AWS_SNS_SMS_TYPE=Transactional
AWS_SNS_SENDER_ID=AirPay
AWS_SNS_DEFAULT_COUNTRY_CODE=+1

# AWS SES (Email)
AWS_SES_FROM_EMAIL=noreply@yourdomain.com
AWS_SES_FROM_NAME=AirPay Messenger
AWS_SES_REPLY_TO_EMAIL=support@yourdomain.com
AWS_SES_CONFIGURATION_SET=airpay-ses-config

# AWS S3 (File Storage)
AWS_S3_BUCKET=airpay-messenger-attachments
AWS_S3_REGION=us-east-1
AWS_S3_PRESIGNED_URL_EXPIRES=3600

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Message Queue
BULL_ATTEMPTS=3
BULL_BACKOFF_DELAY=5000
BULL_REMOVE_ON_COMPLETE=100
BULL_REMOVE_ON_FAIL=200

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CloudWatch Logs (optional)
CLOUDWATCH_GROUP_NAME=airpay-messenger
CLOUDWATCH_STREAM_NAME=application-logs
ENABLE_CLOUDWATCH_LOGS=false

# Feature Flags
ENABLE_SMS_FALLBACK=true
ENABLE_EMAIL_TRACKING=true
ENABLE_MESSAGE_ENCRYPTION=false

# Webhook URLs (for incoming messages)
BASE_WEBHOOK_URL=https://yourdomain.com/api/v1/webhooks

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# File Upload
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Email Configuration (if not using AWS SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# Compliance
DATA_RETENTION_DAYS=365
ENABLE_GDPR_MODE=true
