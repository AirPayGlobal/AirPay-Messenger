// Prisma Schema for AirPay Messenger

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Contacts - People who can receive messages
model Contact {
  id          String   @id @default(uuid())
  email       String?  @unique
  phone       String?  @unique
  whatsappId  String?  @unique @map("whatsapp_id")
  firstName   String?  @map("first_name") @db.VarChar(100)
  lastName    String?  @map("last_name") @db.VarChar(100)
  metadata    Json?    @db.JsonB
  preferences Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages          Message[]
  messageRecipients MessageRecipient[]

  @@index([email])
  @@index([phone])
  @@index([whatsappId])
  @@map("contacts")
}

// Messages - All sent and received messages
model Message {
  id              String         @id @default(uuid())
  contactId       String         @map("contact_id")
  channel         MessageChannel
  direction       MessageDirection
  status          MessageStatus
  subject         String?        @db.VarChar(255)
  body            String?        @db.Text
  htmlBody        String?        @map("html_body") @db.Text
  templateId      String?        @map("template_id")
  metadata        Json?          @db.JsonB
  externalId      String?        @map("external_id") @db.VarChar(255)
  parentMessageId String?        @map("parent_message_id")
  scheduledAt     DateTime?      @map("scheduled_at")
  sentAt          DateTime?      @map("sent_at")
  deliveredAt     DateTime?      @map("delivered_at")
  readAt          DateTime?      @map("read_at")
  failedAt        DateTime?      @map("failed_at")
  errorMessage    String?        @map("error_message") @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  contact           Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  template          Template?          @relation(fields: [templateId], references: [id], onDelete: SetNull)
  parentMessage     Message?           @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  childMessages     Message[]          @relation("MessageThread")
  attachments       Attachment[]
  messageRecipients MessageRecipient[]
  queueJobs         MessageQueueJob[]

  @@index([contactId])
  @@index([channel])
  @@index([status])
  @@index([direction])
  @@index([externalId])
  @@index([createdAt])
  @@index([scheduledAt])
  @@map("messages")
}

// Message Recipients - For CC/BCC in emails
model MessageRecipient {
  id            String        @id @default(uuid())
  messageId     String        @map("message_id")
  contactId     String        @map("contact_id")
  recipientType RecipientType @map("recipient_type")
  createdAt     DateTime      @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([contactId])
  @@map("message_recipients")
}

// Templates - Reusable message templates
model Template {
  id              String         @id @default(uuid())
  name            String         @unique @db.VarChar(100)
  channel         MessageChannel
  subjectTemplate String?        @map("subject_template") @db.VarChar(255)
  bodyTemplate    String         @map("body_template") @db.Text
  htmlTemplate    String?        @map("html_template") @db.Text
  variables       Json?          @db.JsonB
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  messages Message[]

  @@index([channel])
  @@index([isActive])
  @@map("templates")
}

// Attachments - Files attached to messages
model Attachment {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  fileName  String   @map("file_name") @db.VarChar(255)
  fileType  String   @map("file_type") @db.VarChar(100)
  fileSize  Int      @map("file_size")
  s3Key     String   @map("s3_key") @db.VarChar(500)
  s3Url     String   @map("s3_url") @db.VarChar(1000)
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

// Webhook Logs - Incoming webhook events
model WebhookLog {
  id           String    @id @default(uuid())
  source       String    @db.VarChar(50)
  eventType    String    @map("event_type") @db.VarChar(100)
  payload      Json      @db.JsonB
  processed    Boolean   @default(false)
  processedAt  DateTime? @map("processed_at")
  errorMessage String?   @map("error_message") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([source])
  @@index([processed])
  @@index([createdAt])
  @@map("webhook_logs")
}

// API Keys - For authentication
model ApiKey {
  id          String    @id @default(uuid())
  keyHash     String    @unique @map("key_hash") @db.VarChar(255)
  name        String    @db.VarChar(100)
  serviceName String    @map("service_name") @db.VarChar(100)
  permissions Json?     @db.JsonB
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([isActive])
  @@index([expiresAt])
  @@map("api_keys")
}

// Message Queue Jobs - Track queue processing
model MessageQueueJob {
  id           String           @id @default(uuid())
  messageId    String           @map("message_id")
  jobId        String           @map("job_id") @db.VarChar(255)
  status       QueueJobStatus
  retryCount   Int              @default(0) @map("retry_count")
  maxRetries   Int              @default(3) @map("max_retries")
  errorMessage String?          @map("error_message") @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([jobId])
  @@index([status])
  @@map("message_queue_jobs")
}

// Enums
enum MessageChannel {
  whatsapp
  sms
  email
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageStatus {
  queued
  sent
  delivered
  read
  failed
  bounced
}

enum RecipientType {
  to
  cc
  bcc
}

enum QueueJobStatus {
  pending
  processing
  completed
  failed
}
